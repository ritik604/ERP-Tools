{% extends 'base.html' %}

{% block title %}Project Sites{% endblock %}

{% block content %}

<div class="row pt-3 pb-2 mb-3 border-bottom">
    <div class="col-md-6">
        <h1 class="h2">Project Sites</h1>
    </div>
    <div class="col-md-6">
        <div class="btn-toolbar mb-2 mb-md-0 float-end">
            <a href="{% url 'projects:project_create' %}" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-plus-lg"></i> New Project Site
            </a>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="GET" class="d-flex">
            <input type="text" name="q" class="form-control me-2" placeholder="Search projects..."
                value="{{ request.GET.q }}">
            <select name="status" class="form-select me-2">
                <option value="">All Statuses</option>
                <option value="ACTIVE" {% if request.GET.status=='ACTIVE' %}selected{% endif %}>Active</option>
                <option value="COMPLETED" {% if request.GET.status=='COMPLETED' %}selected{% endif %}>Completed</option>
                <option value="ON_HOLD" {% if request.GET.status=='ON_HOLD' %}selected{% endif %}>On Hold</option>
            </select>
            <button type="submit" class="btn btn-outline-primary">Filter</button>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th scope="col">Site ID</th>
                <th scope="col">Name</th>
                <th scope="col">Start Date</th>
                <th scope="col">Status</th>
                <th scope="col">Action</th>
            </tr>
        </thead>
        <tbody>
            {% for project in projects %}
            <tr>
                <td>{{ project.site_id }}</td>
                <td>{{ project.name }}</td>
                <td>{{ project.start_date }}</td>
                <td>
                    {% if project.status == 'ACTIVE' %}
                    <span class="badge bg-success">Active</span>
                    {% elif project.status == 'COMPLETED' %}
                    <span class="badge bg-secondary">Completed</span>
                    {% else %}
                    <span class="badge bg-warning">On Hold</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{% url 'projects:project_detail' project.pk %}"
                        class="btn btn-sm btn-info text-white">View</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}