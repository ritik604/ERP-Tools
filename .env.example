# ManageX ERP - Environment Variables Template
# Copy this file to .env and fill in your values

# 1. SECURITY & DEBUG
# ---------------------------------------------------------
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# 2. NETWORK
# ---------------------------------------------------------
# Comma-separated list of allowed hosts (e.g., localhost,yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF
CSRF_TRUSTED_ORIGINS=https://localhost:8000,https://127.0.0.1:8000

# 3. DATABASE (Optional - default is SQLite)
# ---------------------------------------------------------
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
